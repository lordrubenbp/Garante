# Copia este archivo a .env y rellena los valores.
# Todas las variables son opcionales: sin ellas, la aplicación arranca
# en modo demo offline sobre datos sintéticos.

# Conexión a MongoDB (perfiles de investigadores)
MONGO_URI=
MONGO_DB=

# Clave de la API de Claude (Anthropic) para la evaluación cualitativa con IA
ANTHROPIC_API_KEY=

# Correo de contacto para el "polite pool" de la API de OpenAlex
OPENALEX_MAILTO=
